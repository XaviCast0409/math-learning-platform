                                "b": "1/8",
                                "c": "-1/8",
                                "d": "8"
                            },
                            "correct_answer": "b",
                            "solution_explanation": "$$ 2^{-3} = \\frac{1}{2^3} = \\frac{1}{8} $$"
                        },
                        {
                            "type": "fill_in",
                            "difficulty": 3,
                            "prompt": "Simplifica: $$ \\frac{x^{-4}}{x^{-7}} = x^? $$",
                            "correct_answer": "3",
                            "solution_explanation": "$$ x^{-4-(-7)} = x^{-4+7} = x^3 $$"
                        },
