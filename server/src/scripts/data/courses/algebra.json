                            "correct_answer": "c",
                            "solution_explanation": "El doble del primero por el segundo es $$ 2(x)(3) = 6x $$."
                        },
                        {
                            "type": "multiple_choice",
                            "difficulty": 2,
                            "prompt": "Desarrolla: $$ (2x-5)^2 $$",
