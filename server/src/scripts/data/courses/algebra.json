                                "d": "4x^2 + 25"
                            },
                            "correct_answer": "b",
                            "solution_explanation": "$$ (2x)^2 - 2(2x)(5) + 5^2 = 4x^2 - 20x + 25 $$"
                        },
                        {
                            "type": "fill_in",
                            "difficulty": 3,
                            "prompt": "Si $$ (x+k)^2 = x^2 + 10x + 25 $$, entonces $$ k = ? $$",
                            "correct_answer": "5",
                            "solution_explanation": "$$ 2k = 10 $$, entonces $$ k = 5 $$"
                        }
