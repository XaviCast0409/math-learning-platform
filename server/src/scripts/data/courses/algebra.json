                                "a": "12",
                                "b": "64",
                                "c": "81",
                                "d": "27"
                            },
                            "correct_answer": "c",
                            "solution_explanation": "$$ 3 \\times 3 \\times 3 \\times 3 = 81 $$"
                        },
